{
  "hooks": {
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Projects/my-assistant/.claude/hooks/pre-compact.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Projects/my-assistant/.claude/hooks/pre-bash-git-push-block.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Projects/my-assistant/.claude/hooks/post-edit-js-check.sh"
          },
          {
            "type": "command",
            "command": "bash ~/Projects/my-assistant/.claude/hooks/post-edit-console-warn.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/Projects/my-assistant/.claude/hooks/evaluate-session.sh"
          },
          {
            "type": "command",
            "command": "bash ~/Projects/my-assistant/.claude/hooks/session-end.sh"
          }
        ]
      }
    ]
  }
}
